# Deepgram API key — get one at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Server config
WS_PORT=8080

# Deepgram options
DG_MODEL=nova-3
DG_LANGUAGE=multi
# Region: "us" (default, https://api.deepgram.com) or "eu". NOTE: the EU endpoint
# (api.eu.deepgram.com) is NOT directly reachable — it requires a GDPR/enterprise
# proxy you deploy in-region. To use it, set DG_REGION=eu AND DG_EU_PROXY_URL to
# your proxy. Otherwise leave this as "us".
DG_REGION=us
# DG_EU_PROXY_URL=https://your-eu-proxy.example.com
